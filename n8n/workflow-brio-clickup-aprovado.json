      "id": "00f0652c-12ea-4643-9701-d3422c38a96c",
      "name": "Responder tarefa aprovada"
    },
    {
      "parameters": {
        "jsCode": "const current = $json;\nconst data = current.data || current;\n\nconst caption = data.caption || '';\n\nconst simulatedPrompt = `\nCom base na legenda abaixo, gere sugestões de hashtags para Instagram.\nSepare as hashtags em amplas, nichadas e marca/operacionais.\n\nLegenda:\n${caption}\n`;\n\nconst hashtags = {\n  amplas: [\n    '#odontologia',\n    '#saudebucal',\n    '#sorriso',\n    '#esteticaDental'\n  ],\n  nichadas: [\n    '#clareamentoDental',\n    '#odontologiaEstetica',\n    '#lentesDeContatoDental',\n    '#sorrisoNatural'\n  ],\n  operacionais: [\n    '#conteudoEducativo',\n    '#postInstagram',\n    '#brioLab'\n  ]\n};\n\nreturn [\n  {\n    json: {\n      ok: true,\n      processed: true,\n      message: 'Payload aprovado processado e hashtags geradas com IA simulada.',\n      data: {\n        ...data,\n        ai: {\n          provider: 'simulado',\n          model: 'mock-instagram-hashtags',\n          prompt: simulatedPrompt.trim(),\n          hashtags,\n          hashtags_flat: [\n            ...hashtags.amplas,\n            ...hashtags.nichadas,\n            ...hashtags.operacionais\n          ]\n        }\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -80
      ],
      "id": "450169aa-5483-4210-a7cd-b3f7e2f202cc",
      "name": "Gerar hashtags com IA simulada"
    },
    {
      "parameters": {
        "jsCode": "const current = $json;\nconst data = current.data || current;\n\nconst storageRecord = {\n  task_id: data.task_id,\n  task_name: data.task_name,\n  task_url: data.task_url,\n  caption: data.caption,\n  post_date: data.post_date,\n  content_type: data.content_type,\n  ai_provider: data.ai?.provider || 'simulado',\n  hashtags: data.ai?.hashtags_flat || [],\n  hashtags_amplas: data.ai?.hashtags?.amplas || [],\n  hashtags_nichadas: data.ai?.hashtags?.nichadas || [],\n  hashtags_operacionais: data.ai?.hashtags?.operacionais || [],\n  processed_status: 'ready_to_persist',\n  created_at: new Date().toISOString()\n};\n\nreturn [\n  {\n    json: {\n      ...current,\n      data: {\n        ...data,\n        storage: storageRecord\n      }\n    }\n  }\n];"
      },
