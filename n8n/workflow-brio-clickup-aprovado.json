    {
      "parameters": {
        "jsCode": "const payload = $json.body || $json;\nconst task = payload.task || payload;\n\nfunction getStatus(task) {\n  if (typeof task.status === 'string') {\n    return task.status;\n  }\n\n  if (task.status?.status) {\n    return task.status.status;\n  }\n\n  return null;\n}\n\nfunction getCustomField(task, fieldName) {\n  const fields = task.custom_fields || [];\n\n  const field = fields.find((item) => {\n    const name = item.name || item.field_name || '';\n    return name.toLowerCase() === fieldName.toLowerCase();\n  });\n\n  return field?.value ?? null;\n}\n\nconst extractedData = {\n  task_id: task.id,\n  task_name: task.name,\n  description: task.description,\n  status: getStatus(task),\n  task_url: task.url,\n  caption: getCustomField(task, 'legenda'),\n  post_date: getCustomField(task, 'data_postagem'),\n  content_type: getCustomField(task, 'tipo_conteudo'),\n};\n\nreturn [\n  {\n    json: {\n      ok: true,\n      processed: true,\n      message: 'Payload aprovado recebido e dados extraídos com sucesso.',\n      data: extractedData,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        -80
      ],
      "id": "aa7df85d-8f2e-4b05-9bf2-d046be6b0749",
      "name": "Extrair dados da tarefa"
    },
